# B&M Brand & More — Next.js Environment Configuration
# Copy this file to .env.local and fill in your credentials

# Site URL (used by next-sitemap)
SITE_URL=https://brandandmore.ae

# SMTP Configuration (for Nodemailer contact form emails)
# Option A: Gmail (use App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# The email address that receives form submissions
CONTACT_EMAIL=info@brandandmore.ae

# Google Analytics (optional — add your GA4 Measurement ID)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
